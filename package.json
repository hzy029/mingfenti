{
  "name": "mingqing-detector",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run generate:library-index",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "generate:library-index": "tsx scripts/generate-library-index.ts",
    "generate:library-index:check": "tsx scripts/generate-library-index.ts --check-only",
    "import:library-from-references": "tsx scripts/import-library-from-references.ts",
    "export:lite-judgment-md": "tsx scripts/export-lite-judgment-md.ts",
    "generate:lite-bank": "tsx scripts/generate-lite-bank-data.ts",
    "generate:lite-bank:check": "tsx scripts/generate-lite-bank-data.ts --check-only",
    "precf:build": "npm run generate:library-index",
    "cf:build": "npx @opennextjs/cloudflare build",
    "cf:deploy": "npx @opennextjs/cloudflare deploy",
    "preview": "npm run cf:build && npx @opennextjs/cloudflare preview",
    "deploy": "npm run cf:build && npm run cf:deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "d1:create": "wrangler d1 create mingqing-detector",
    "d1:apply:local": "wrangler d1 execute mingqing-detector --local --file=./schema.sql",
    "d1:apply:remote": "wrangler d1 execute mingqing-detector --remote --file=./schema.sql",
    "d1:count:remote": "wrangler d1 execute mingqing-detector --remote --command=\"SELECT COUNT(*) AS count FROM basic_attempts;\""
  },
  "dependencies": {
    "lucide-react": "latest",
    "next": "latest",
    "qrcode": "^1.5.4",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@opennextjs/cloudflare": "latest",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/qrcode": "^1.5.6",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "tsx": "^4.21.0",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
